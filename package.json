{
  "name": "dimorphic-git",
  "version": "2.0.0-alpha",
  "description": "A pure JavaScript reimplementation of git for node and browsers",
  "type": "module",
  "typings": "./index.d.cts",
  "main": "./index.cjs",
  "module": "./index.js",
  "exports": {
    ".": {
      "types": "./index.d.cts",
      "default": "./index.cjs"
    },
    "./http/node": {
      "import": {
        "types": "./http/node/index.d.ts",
        "default": "./http/node/index.js"
      },
      "require": {
        "types": "./http/node/index.d.cts",
        "default": "./http/node/index.cjs"
      }
    },
    "./http/web": {
      "import": {
        "types": "./http/web/index.d.ts",
        "default": "./http/web/index.js"
      },
      "require": {
        "types": "./http/web/index.d.cts",
        "default": "./http/web/index.cjs"
      }
    },
    "./managers": {
      "import": {
        "types": "./managers/index.d.ts",
        "default": "./managers/index.js"
      },
      "require": {
        "types": "./managers/index.d.cts",
        "default": "./managers/index.cjs"
      }
    },
    "./models": {
      "import": {
        "types": "./models/index.d.ts",
        "default": "./models/index.js"
      },
      "require": {
        "types": "./models/index.d.cts",
        "default": "./models/index.cjs"
      }
    }
  },
  "unpkg": "./index.umd.min.js",
  "bin": {
    "dimogit": "./cli.cjs"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=14.17"
  },
  "scripts": {
    "start": "nps",
    "format": "nps format",
    "build": "nps build",
    "test": "nps test",
    "publish-website": "nps website",
    "prepublishOnly": "nps prepublish",
    "semantic-release": "semantic-release",
    "add-contributor": "nps contributors.add"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chebizarro/dimorphic-git.git"
  },
  "keywords": [
    "git",
    "isomorphic"
  ],
  "author": "Chebizarro <chebizarro@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/chebizarro/dimorphic-git/issues"
  },
  "homepage": "https://github.com/chebizarro/dimorphic-git/",
  "files": [
    "cli.cjs",
    "browser-tests.json",
    "http/*",
    "index.cjs",
    "index.d.cts",
    "index.js",
    "index.d.ts",
    "index.umd.min.js",
    "index.umd.min.d.ts",
    "index.umd.min.js.map",
    "size_report.html",
    "managers/*",
    "models/*"
  ],
  "dependencies": {
    "async-lock": "^1.4.1",
    "clean-git-ref": "^2.0.1",
    "crc-32": "^1.2.2",
    "diff3": "0.0.3",
    "ignore": "^5.3.2",
    "minimisted": "^2.0.1",
    "pako": "^1.0.11",
    "path-browserify": "^1.0.1",
    "pify": "^4.0.1",
    "readable-stream": "^3.6.2",
    "sha.js": "^2.4.12",
    "simple-get": "^4.0.1"
  },
  "devDependencies": {
    "@babel/core": "7.6.0",
    "@babel/plugin-transform-async-to-generator": "7.5.0",
    "@babel/preset-env": "7.5.5",
    "@babel/runtime": "7.5.5",
    "@isomorphic-git/cors-proxy": "2.7.1",
    "@isomorphic-git/lightning-fs": "^3.4.2",
    "@isomorphic-git/pgp-plugin": "0.0.7",
    "@semantic-release/exec": "5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@wmhilton/jest-fixtures": "0.6.1",
    "@zenfs/core": "^2.5.6",
    "agadoo": "2.0.0",
    "all-contributors-cli": "6.20.0",
    "babel-core": "7.0.0-bridge.0",
    "babel-loader": "8.3.0",
    "browserfs": "2.0.0",
    "bundlewatch": "^0.4.1",
    "cross-env": "6.0.0",
    "decompress": "^4.2.1",
    "duplicate-package-checker-webpack-plugin": "3.0.0",
    "envify": "4.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-prettier-standard": "^4.0.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-prettier": "^3.4.1",
    "eslint-plugin-promise": "^6.0.0",
    "git-http-mock-server": "2.0.0",
    "github-comment": "1.0.1",
    "inquirer": "^7.3.3",
    "jasmine-core": "^3.99.1",
    "jest": "^29.7.0",
    "jest-junit": "^15.0.0",
    "jest-puppeteer": "^11.0.0",
    "jsdoc-api": "5.0.3",
    "make-index": "^0.0.4",
    "markdown-table": "^2.0.0",
    "nps": "^5.10.0",
    "nps-utils": "1.7.0",
    "prettier": "1.19.1",
    "prettier-config-standard": "^1.0.1",
    "pretty-format": "24.9.0",
    "puppeteer": "^24.41.0",
    "replace-in-file": "4.1.3",
    "rollup": "1.29.1",
    "semantic-release": "17.4.7",
    "socks-proxy-agent": "^8.0.5",
    "ssh2": "^1.17.0",
    "standard": "^17.1.2",
    "timeout-cli": "0.3.2",
    "typescript": "5.7.3",
    "webpack": "4.41.5",
    "webpack-bundle-analyzer": "3.4.1",
    "webpack-cli": "3.3.7"
  },
  "prettier": "./.prettierrc.cjs",
  "bundlewatch": {
    "files": [
      {
        "path": "./index.umd.min.js",
        "maxSize": "100kb"
      }
    ],
    "ci": {
      "trackBranches": [
        "main"
      ]
    }
  },
  "peerDependencies": {
    "socks-proxy-agent": "^8.0.0",
    "ssh2": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "ssh2": {
      "optional": true
    },
    "socks-proxy-agent": {
      "optional": true
    }
  }
}
